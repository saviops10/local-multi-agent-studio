{
  "name": "local-multi-agent-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build --outDir dist-client",
    "build:server": "tsc server.ts --outDir dist-server --module CommonJS --moduleResolution node --target ES2022 --allowJs --skipLibCheck --esModuleInterop",
    "build:exe": "node build-and-pack.js",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-client dist-server bin-output release production-build dist-final",
    "lint": "tsc --noEmit"
  },
  "bin": "index.js",
  "pkg": {
    "assets": [
      "dist-client/**/*",
      "index.js",
      "studio.db",
      "data/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "overrides": {
    "dompurify": "^3.3.3"
  }
}
